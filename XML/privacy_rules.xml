<?xml version="1.0" encoding="UTF-8"?> 
<PrivacyRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="privacy_rules.xsd">

    <OwnershipDefinitions>
        <Ownership role="doctor" attribute="doct_id"/>
        <Ownership role="nurse" attribute="nurse_id"/>
        <Ownership role="helper" attribute="helper_id"/>
    </OwnershipDefinitions>

    <RuleSets>
        <RuleSet role="doctor">

            <TableRule table="MedicalRecord">
                <RowFilter ownership="doctor"/>
            </TableRule>

            <TableRule table="Patients">
                <RowFilter ownership="doctor"/>
            </TableRule>

            <TableRule table="Appointment">
                <RowFilter ownership="doctor"/>
                <MaskColumns>
                    <Column>mode_of_payment</Column>
                    <Column>mode_of_appointment</Column>
                    <!--Doctor shouldn’t be able to see payment_amount, so added this column as well -->
                    <Column>payment_amount</Column>
                </MaskColumns>
            </TableRule>

        </RuleSet>

        <RuleSet role="helper">
        
            <TableRule table="BedRecords">
                <RowFilter ownership="helper"/>
                <MaskColumns>
                    <Column>mode_of_payment</Column>
                    <Column>amount</Column>
                </MaskColumns>
            </TableRule>

            <TableRule table="RoomRecords">
                <RowFilter ownership="helper"/>
                <MaskColumns>
                    <Column>mode_of_payment</Column>
                    <Column>amount</Column>
                </MaskColumns>
            </TableRule>

            <TableRule table="SurgeryRecord">
                <RowFilter>
                    <Condition type="complex"> 
                        <Logic operator="AND">
                            <Condition ownership="helper"/>
                            <Condition>SurgeryRecord.surgery_Date = CURRENT_DATE</Condition>
                        </Logic> 
                    </Condition>
                </RowFilter> 
            </TableRule>

            <TableRule table="StaffShift">
                <RowFilter ownership="helper"/>
            </TableRule>

            <TableRule table="Room">
                <RowFilter ownership="helper"/>
            </TableRule>

            <TableRule table="Ward">
                <RowFilter ownership="helper"/>
            </TableRule>

            <TableRule table="Bed">
                <RowFilter ownership="helper"/>
            </TableRule>

        </RuleSet>

        <RuleSet role="nurse">

            <TableRule table="Patients">
                <RowFilter ownership="nurse"/>
                <MaskColumns>
                    <Column>pt_Address</Column>
                </MaskColumns>
            </TableRule>

            <TableRule table="BedRecords">
                <RowFilter ownership="nurse"/>
                <MaskColumns>
                    <Column>mode_of_payment</Column>
                    <Column>amount</Column>
                </MaskColumns>
            </TableRule>

            <TableRule table="RoomRecords">
                <RowFilter ownership="nurse"/>
                <MaskColumns>
                    <Column>mode_of_payment</Column>
                    <Column>amount</Column>
                </MaskColumns>
            </TableRule>

            <TableRule table="SurgeryRecord">
                <RowFilter>
                    <Condition type="complex"> 
                        <Logic operator="AND">
                            <Condition ownership="nurse"/>
                            <Condition>SurgeryRecord.surgery_Date = CURRENT_DATE</Condition>
                        </Logic> 
                    </Condition>
                </RowFilter> 
            </TableRule>

            <TableRule table="MedicalRecord">
                <RowFilter ownership="nurse"/>
            </TableRule>

            <TableRule table="StaffShift">
                <RowFilter ownership="nurse"/>
            </TableRule>

            <TableRule table="Room">
                <RowFilter ownership="nurse"/>
            </TableRule>

            <TableRule table="Ward">
                <RowFilter ownership="nurse"/>
            </TableRule>

            <TableRule table="Bed">
                <RowFilter ownership="nurse"/>
            </TableRule>

        </RuleSet>
    </RuleSets>

</PrivacyRules>
