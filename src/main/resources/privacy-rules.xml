<?xml version="1.0" encoding="UTF-8"?>
<PrivacyRules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="privacy_rules_final.xsd">

    <RuleSet role="doctor">
        <TableRule table="MedicalRecord">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>doct_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
        </TableRule>

        <TableRule table="Appointment">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>doct_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
            <Anonymization>
                <Attribute column="payment_amount" type="IDENTIFYING"/>
                <Attribute column="mode_of_payment" type="QUASI_IDENTIFYING"/>
                <Attribute column="mode_of_appointment" type="QUASI_IDENTIFYING"/>
                <PrivacyModels>
                    <KAnonymity k="2"/>
                </PrivacyModels>
            </Anonymization>
        </TableRule>
    </RuleSet>

    <RuleSet role="nurse">
        <TableRule table="Patient">
            <Anonymization>
                <Attribute column="FName" type="IDENTIFYING"/>
                <Attribute column="LName" type="IDENTIFYING"/>
                <Attribute column="pt_Address" type="QUASI_IDENTIFYING"/>
                <Attribute column="Date_Of_Birth" type="QUASI_IDENTIFYING"/>
                <PrivacyModels>
                    <KAnonymity k="5"/>
                </PrivacyModels>
            </Anonymization>
        </TableRule>

        <TableRule table="MedicalRecord">
            <Anonymization>
                <Attribute column="visit_Date" type="QUASI_IDENTIFYING"/>
                <Attribute column="diagnosis" type="SENSITIVE"/>
                <PrivacyModels>
                    <KAnonymity k="3"/>
                    <LDiversity column="diagnosis" l="3"/>
                </PrivacyModels>
            </Anonymization>
        </TableRule>

        <TableRule table="BedRecord">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>nurse_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
            <MaskColumns>
                <Column>mode_of_payment</Column>
                <Column>amount</Column>
            </MaskColumns>
        </TableRule>

        <TableRule table="RoomRecord">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>nurse_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
            <MaskColumns>
                <Column>mode_of_payment</Column>
                <Column>amount</Column>
            </MaskColumns>
        </TableRule>

        <TableRule table="SurgeryRecord">
            <RowFilter>
                <Logic operator="AND">
                    <Condition operator="eq">
                        <LeftOperand><Column>nurse_Id</Column></LeftOperand>
                        <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                    </Condition>
                    <Condition operator="eq">
                        <LeftOperand><Column>surgery_Date</Column></LeftOperand>
                        <RightOperand><ContextAttribute>currentDate</ContextAttribute></RightOperand>
                    </Condition>
                </Logic>
            </RowFilter>
        </TableRule>

        <TableRule table="StaffShift">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>nurse_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
        </TableRule>
    </RuleSet>

    <RuleSet role="helper">
        <TableRule table="BedRecord">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>helper_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
            <Anonymization>
                <Attribute column="patient_Id" type="IDENTIFYING"/>
                <Attribute column="bed_No" type="QUASI_IDENTIFYING"/>
                <Attribute column="amount" type="SENSITIVE"/>
                <PrivacyModels>
                    <KAnonymity k="10"/>
                    <TCloseness column="amount" t="0.2"/>
                </PrivacyModels>
            </Anonymization>
        </TableRule>

        <TableRule table="RoomRecord">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>helper_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
            <MaskColumns>
                <Column>mode_of_payment</Column>
                <Column>amount</Column>
            </MaskColumns>
        </TableRule>

        <TableRule table="SurgeryRecord">
            <RowFilter>
                <Logic operator="AND">
                    <Condition operator="eq">
                        <LeftOperand><Column>helper_Id</Column></LeftOperand>
                        <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                    </Condition>
                    <Condition operator="eq">
                        <LeftOperand><Column>surgery_Date</Column></LeftOperand>
                        <RightOperand><ContextAttribute>currentDate</ContextAttribute></RightOperand>
                    </Condition>
                </Logic>
            </RowFilter>
        </TableRule>

        <TableRule table="StaffShift">
            <RowFilter>
                <Condition operator="eq">
                    <LeftOperand><Column>helper_Id</Column></LeftOperand>
                    <RightOperand><ContextAttribute>databaseId</ContextAttribute></RightOperand>
                </Condition>
            </RowFilter>
        </TableRule>
    </RuleSet>

</PrivacyRules>